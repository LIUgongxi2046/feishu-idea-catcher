# Shared secret used between the local worker and optional Vercel HTTP API.
# Generate with: openssl rand -hex 32
WORKER_API_TOKEN=change-me-to-a-long-random-token

# Upstash Redis REST API. Used as the durable queue and job store.
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Feishu/Lark self-built app credentials.
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# Optional only when you use HTTP callback mode instead of long connection.
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Optional Vercel API base URL when WORKER_QUEUE_SOURCE=cloud.
CLOUD_API_BASE_URL=https://your-vercel-project.vercel.app
VERCEL_SCOPE=

# Obsidian output paths. Change these to your vault and preferred folder.
OBSIDIAN_IDEA_LIST_DIR=$HOME/Documents/Obsidian Vault/Ideas
OBSIDIAN_REPORT_DIR=$HOME/Documents/Obsidian Vault/Ideas/plan-ceo-review
OBSIDIAN_VAULT_ROOT=$HOME/Documents/Obsidian Vault
OBSIDIAN_VAULT_NAME=Obsidian Vault

# Local binaries.
CODEX_BIN=/Applications/Codex.app/Contents/Resources/codex
CHROME_BIN=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Worker behavior.
WORKER_INTERVAL_SECONDS=30
WORKER_QUEUE_SOURCE=upstash

# Report and research. The default uses local Codex CLI with web search.
REPORT_ENGINE=codex
REPORT_PERSONA=架构评审助手
RESEARCH_ENGINE=codex
CODEX_REPORT_TIMEOUT_MS=1200000
CODEX_ENABLE_WEB_SEARCH=1

# PDF export. chrome: fully automatic. obsidian: Markdown only. none: skip.
PDF_RENDERER=chrome
PDF_OUTPUT_DIR=/tmp/feishu-idea-catcher-pdf

# Whiteboard image generation.
# codex uses the local Codex app image generation ability; openai uses API fallback; none skips images.
IMAGE_ENGINE=codex
CODEX_IMAGE_TIMEOUT_MS=900000
WHITEBOARD_SIGNATURE=

# Optional OpenAI API image fallback when IMAGE_ENGINE=openai.
IMAGE_MODEL=gpt-image-1
IMAGE_SIZE=1536x1024
OPENAI_API_KEY=

# Optional official search providers when RESEARCH_ENGINE=external.
# SEARCH_PROVIDER=brave
# BRAVE_SEARCH_API_KEY=
# SEARCH_PROVIDER=bing
# BING_SEARCH_API_KEY=
# SEARCH_PROVIDER=tavily
# TAVILY_API_KEY=
